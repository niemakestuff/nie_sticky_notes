{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nie Sticky Notes",
  "version": "1.0.0",
  "identifier": "niemakestuff.nie-sticky-notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Microsoft Sticky Notes clone but better.",
    "longDescription": "Microsoft Sticky Notes clone but better.",
    "publisher": "niemakestuff",
    "copyright": "Copyright © 2026 Nie (niemakestuff)",
    "licenseFile": "../LICENSE",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}